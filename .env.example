# Thoughtful Frame - Unraid Configuration Example
# Copy this file to .env and customize the values below

# Your Unraid server IP and Immich port
# Default: http://192.168.1.180:8080/api
IMMICH_BASE_URL=http://192.168.1.180:8080/api

# Your Immich API key (required)
# Get this from Immich → Account Settings → API Keys
IMMICH_API_KEY=your_immich_api_key_here

# Database file path (inside container)
DATABASE_PATH=/data/thoughtful_frame.db

# Volume: /mnt/user/appdata/thoughtful-frame (see docker-compose.yml)
# To change location, edit the volume mount in docker-compose.yml

# Unraid user/group IDs (optional)
# Match these to your Unraid user so file permissions are correct
# Default: 99/100 (Unraid's nobody/users — works for most setups)
# PUID=99
# PGID=100

# App password (optional but recommended)
# If set, a login screen protects the app from unauthorized access on your network.
# Leave blank to disable authentication.
# APP_PASSWORD=change_me

# Debug mode (optional)
# Set to 'true' for more verbose logging during troubleshooting
DEBUG_MODE=false

# Immich API pagination (optional)
# Controls how many images are fetched per page from Immich
# Default: 100 (increased from 50 for better browsing experience)
# IMMICH_PAGE_SIZE=200